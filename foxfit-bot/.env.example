# ===== Facebook Messenger =====
PAGE_ACCESS_TOKEN=      # Page Access Token lấy từ Meta Developer > Messenger > Settings
VERIFY_TOKEN=foxfit_verify_2026   # Token tự đặt, phải khớp với ô Verify Token khi set webhook
APP_SECRET=             # App Secret (Meta App > Settings > Basic). Dùng để verify chữ ký X-Hub-Signature

# ===== Claude (Anthropic) =====
ANTHROPIC_API_KEY=      # sk-ant-... lấy từ console.anthropic.com
MODEL_SIMPLE=claude-haiku-4-5      # model cho câu thường (rẻ)
MODEL_COMPLEX=claude-sonnet-4-6    # model cho câu tư vấn phức tạp

# ===== Telegram (báo cáo) =====
TELEGRAM_BOT_TOKEN=     # Token từ @BotFather
TELEGRAM_CHAT_ID=       # Chat ID nhận báo cáo (xem README cách lấy)

# ===== Server =====
PORT=3000
TZ=Asia/Ho_Chi_Minh    # để cron 21:00 chạy đúng giờ VN
